  },
  "devDependencies": {
    "@types/chrome": ">=0.0.260",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
